# v0.2 BPF build artifacts — host-kernel bound, never committed.
# R-CLI1 reproducibility comes from the Makefile rule that regenerates
# these, not from the bytes on disk.
edr/EDR/internal/bpf/probes/vmlinux.h
edr/EDR/internal/bpf/probes/*.bpf.o
edr/EDR/internal/bpf/probes/*.bpf.linked.o

# Go test coverage + gofumpt module cache
*.test
*.out
coverage.txt

# Local scratch
edr/EDR/var/
*.swp
.DS_Store

# Go toolchain (host-specific, not project code)
edr/EDR/.tools/

# Compiled binaries
edr/EDR/edr-agent
edr/EDR/edrctl
edr/EDR/edr-enforcer
edr/EDR/edr-orchestrator
edr/EDR/edr-sensor
edr/EDR/edr-supervisor

# BPF probes source directory c/ (intermediate build artifacts)
edr/EDR/internal/bpf/c/

# Runtime generated policy version backups
edr/EDR/configs/.versions/

# Go test temp directories
edr/EDR/internal/control/tmp/

# Development prompt / session transcript files
EDR_prompt*.txt
EDR_V0.15_prompt
readme-edr.md

# errcheck linter config
.errcheck

# Go build/package cache
edr/EDR/.cache/
edr/EDR/dist/

# IDE / tool config
.claude/
.serena/
