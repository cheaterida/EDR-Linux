{
  "event_path": "var/enforcer-events.jsonl",
  "dry_run": true,
  "retention": {
    "max_bytes": 1048576,
    "max_backups": 3
  },
  "nft": {
    "enabled": false,
    "dry_run": true,
    "table": "edr",
    "chain": "blocklist"
  },
  "transport": {
    "sensor_socket": "var/run/edr-sensor.sock",
    "orchestrator_socket": "var/run/edr-orchestrator.sock",
    "enforcer_socket": "var/run/edr-enforcer.sock",
    "shared_secret": "local-dev-secret"
  },
  "ha": {
    "instance_id": "edr-a",
    "peer_instance_id": "edr-b",
    "priority": 100,
    "run_dir": "var/run/ha",
    "heartbeat_every_sec": 1,
    "suspect_after": 3,
    "down_after": 5,
    "lease_ttl_sec": 10,
    "restart_cooldown_sec": 30
  }
}
