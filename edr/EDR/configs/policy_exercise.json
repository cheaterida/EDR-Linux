      "id": "ROOTKIT-001",
      "description": "Kernel module loaded via init_module/finit_module (detector-generated)",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-002",
      "description": "Hidden process detected via /proc vs BPF mismatch (detector-generated)",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-003",
      "description": "Kernel module unloaded via delete_module (detector-generated)",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-004",
      "description": "Hidden kernel module detected via /sys/module vs /proc/modules mismatch (detector-generated)",
