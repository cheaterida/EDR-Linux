    {
      "id": "P001-suspicious-shell-download",
      "description": "Shell command downloads and executes payload-like content — Day1 alert, Day2 block",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "curl http://"
      },
      "whitelist": [
        {
          "process_path": "/usr/bin/apt"
        },
        {
          "process_path": "/usr/bin/curl"
        }
      ]
    },
    {
      "id": "P002-credential-file-access",
      "description": "Process command line references sensitive credential files",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "/etc/shadow"
      }
    },
    {
      "id": "P003-reverse-shell-pattern",
      "description": "Common bash reverse shell /dev/tcp/ pattern — Day1 alert, Day2 block",
      "category": "process",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "/dev/tcp/"
