{
  "schema_version": "v0.5",
  "rules": [
    {
      "id": "ROOTKIT-001",
      "description": "检测到内核模块加载 (init_module/finit_module)",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-002",
      "description": "/proc 与 BPF 进程列表不一致，检测到隐藏进程",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "kill_tree",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-003",
      "description": "检测到内核模块卸载 (delete_module)",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-004",
      "description": "/sys/module 与 /proc/modules 不一致，检测到隐藏内核模块",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-005",
      "description": "检测到 eBPF 程序操作 (bpf() 系统调用)",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-006",
      "description": "BPF 观测到的远程地址在 /proc/net/tcp 中缺失 — Rootkit 隐藏了网络连接",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "ROOTKIT-007",
      "description": "Syscall Table 完整性异常 — 关键 syscall 地址不在内核 .text 段内",
      "enabled": true,
      "category": "rootkit",
      "severity": "critical",
      "decision": "block",
      "action": "network_isolate",
      "match": {},
      "priority": 5,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "P001-suspicious-shell-download",
      "description": "Shell 命令下载并执行类 payload",
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "curl http://"
      },
      "whitelist": [
        {
          "process_path": "/usr/bin/apt"
        }
      ]
    },
    {
      "id": "P002-credential-file-access",
      "description": "进程命令行引用了敏感凭证文件",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "/etc/shadow"
      }
    },
    {
      "id": "P003-reverse-shell-pattern",
      "description": "常见 bash 反弹 shell 模式 /dev/tcp/",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/dev/tcp/"
      }
    },
    {
      "id": "P003b-python-reverse-shell",
      "description": "Python socket 反弹 shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "socket.socket"
      }
    },
    {
      "id": "P003c-socat-reverse-shell",
      "description": "Socat exec 反弹 shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "exec:"
      }
    },
    {
      "id": "P003d-perl-reverse-shell",
      "description": "Perl IO::Socket 反弹 shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "IO::Socket::INET"
      }
    },
    {
      "id": "P003e-ncat-reverse-shell",
      "description": "Ncat -e 执行反弹 shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "ncat -e"
      }
    },
    {
      "id": "P004-python-listener",
      "description": "Python SimpleHTTPServer 类临时服务",
      "category": "process",
      "severity": "medium",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "http.server"
      }
    },
    {
      "id": "P005-temp-exec",
      "description": "从可写临时目录 /tmp/ 执行程序",
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/tmp/"
      }
    },
    {
      "id": "N001-suspicious-listener",
      "description": "可疑本地监听端口 4444",
      "category": "network",
      "severity": "high",
      "decision": "block",
      "action": "nft_block",
      "match": {
        "protocol": "tcp",
        "local_port": 4444
      }
    },
    {
      "id": "N002-known-bad-remote",
      "description": "连接到已知恶意地址 203.0.113.66",
      "category": "network",
      "severity": "high",
      "decision": "block",
      "action": "nft_block",
      "match": {
        "remote_addr": "203.0.113.66"
      }
    },
    {
      "id": "P006-after-hours-admin",
      "description": "非工作时间执行管理命令",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "useradd"
      },
      "time_window": {
        "start": "20:00",
        "end": "06:00"
      }
    },
    {
      "id": "F001-policy-change",
      "description": "策略文件被修改",
      "category": "file",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path": "configs/policy.json"
      }
    },
    {
      "id": "F002-config-permission-guard",
      "description": "敏感配置目录权限变更",
      "category": "file",
      "severity": "medium",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path_prefix": "configs/",
        "file_op": "write"
      }
    },
    {
      "id": "ATT001-ptrace-self-check",
      "description": "进程使用 ptrace 自检 (反调试技术)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "ptrace_self_check": true
      }
    },
    {
      "id": "ATT002-ld-preload-injection",
      "description": "进程通过 LD_PRELOAD 注入",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "env_contains": "LD_PRELOAD"
      }
    },
    {
      "id": "ATT003-frida-detected",
      "description": "检测到 Frida 插桩框架",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "maps_contains": "frida"
      }
    },
    {
      "id": "ATT004-ld-so-preload-write",
      "description": "修改 /etc/ld.so.preload",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path": "/etc/ld.so.preload",
        "file_op": "write"
      }
    },
    {
      "id": "SELF007-edr-socket-tamper",
      "description": "非授权访问 /run/edr-agent.sock — 防止 Unix socket 替换攻击",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fanotify_deny",
      "match": {
        "file_path": "/run/edr-agent.sock",
        "file_op": "open"
      }
    },
    {
      "id": "CPU-001-cpu-limit-exceeded",
      "description": "进程 CPU 占用异常超标 — 可能的挖矿/fork炸弹/失控进程",
      "enabled": true,
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {},
      "priority": 30,
      "effect": [
        "audit",
        "response"
      ]
    },
    {
      "id": "B001-shadow-access",
