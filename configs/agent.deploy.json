{
  "policy_path": "configs/policy.json",
  "baseline_path": "configs/baseline.json",
  "event_path": "var/events.jsonl",
  "response_path": "var/responses.jsonl",
  "artifact_dir": "var/forensics",
  "socket_path": "var/run/edr-agent.sock",
  "interval_sec": 5,
  "syslog": false,
  "dry_run": true,
  "allowed_uids": [0],
  "retention": {
    "max_bytes": 1048576,
    "max_backups": 3
  },
  "file_watch": {
    "mode": "inotify",
    "paths": ["configs"]
  },
  "nft": {
    "enabled": false,
    "dry_run": true,
    "table": "edr",
    "chain": "blocklist"
  },
  "integrity": {
    "enable_chain": true,
    "key_path": "var/log.key",
    "state_path": "var/events.jsonl.state",
    "algorithm": "sha256"
  },
  "suppression": {
    "process_cooldown_sec": 30,
    "file_cooldown_sec": 60,
    "network_cooldown_sec": 30,
    "rate_per_sec": 10,
    "burst": 10,
    "state_path": "var/suppressor.json"
  },
  "anchor": {
    "enabled": false,
    "url": "",
    "file_path": "var/anchor.json",
    "interval_sec": 60
  },
  "bpf": {
    "enabled": false,
    "obj_dir": "internal/bpf/probes",
    "ringbuf_pages": 256,
    "ringbuf_path": "/sys/fs/bpf/edr/events"
  },
  "fanotify": {
    "enabled": false,
    "paths": ["/etc", "/tmp", "/var/spool/cron", "/usr/local/bin"]
  },
  "signing_key_path": "/var/lib/edr/signing.key",
  "rootkit_detection": {
    "enabled": true,
    "interval_sec": 30,
    "monitor_only": true
  },
  "webhooks": [
    {
      "url": "http://<collector-ip>:9090/v0/events/ingest?source=edge-01",
      "format": "generic",
      "min_severity": "medium",
      "timeout_sec": 5
    }
  ],
  "_webhooks_note": "Multi-machine log concentration: point webhook URL to central collector's /v0/events/ingest endpoint. Set source=<hostname> to identify origin."
}
