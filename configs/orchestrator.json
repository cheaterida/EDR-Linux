{
  "policy_path": "configs/policy.json",
  "baseline_path": "configs/baseline.json",
  "event_path": "var/events.jsonl",
  "response_path": "var/responses.jsonl",
  "artifact_dir": "var/forensics",
  "interval_sec": 5,
  "dry_run": true,
  "allowed_uids": [0],
  "retention": {
    "max_bytes": 1048576,
    "max_backups": 3
  },
  "integrity": {
    "enable_chain": true,
    "key_path": "var/log.key",
    "state_path": "var/events.jsonl.state",
    "algorithm": "sha256"
  },
  "suppression": {
    "process_cooldown_sec": 30,
    "file_cooldown_sec": 60,
    "network_cooldown_sec": 30,
    "rate_per_sec": 10,
    "burst": 10,
    "state_path": "var/suppressor.json"
  },
  "transport": {
    "sensor_socket": "var/run/edr-sensor.sock",
    "orchestrator_socket": "var/run/edr-orchestrator.sock",
    "enforcer_socket": "var/run/edr-enforcer.sock",
    "shared_secret": "local-dev-secret",
    "event_push_every_sec": 2
  },
  "supervisor": {
    "enabled": true,
    "url": "http://127.0.0.1:9099",
    "shared_secret": "local-dev-secret",
    "heartbeat_every_sec": 5,
    "request_timeout_sec": 10,
    "tls_cert_path": "",
    "tls_key_path": "",
    "tls_ca_path": "",
    "tls_server_name": "",
    "require_client_cert": false
  },
  "root_session": {
    "mode": "audit",
    "secret": "local-dev-secret",
    "state_path": "var/root-session-state.json",
    "scan_every_sec": 5,
    "challenge_ttl_sec": 30,
    "grace_sec": 30,
    "bypass_ttl_sec": 300
  },
  "ha": {
    "instance_id": "edr-a",
    "peer_instance_id": "edr-b",
    "priority": 100,
    "run_dir": "var/run/ha",
    "heartbeat_every_sec": 1,
    "suspect_after": 3,
    "down_after": 5,
    "lease_ttl_sec": 10,
    "restart_cooldown_sec": 30,
    "restart_timeout_sec": 15,
    "restart_command": [
      "systemctl",
      "restart",
      "edr-sensor@{{peer_instance_id}}.service",
      "edr-enforcer@{{peer_instance_id}}.service",
      "edr-orchestrator@{{peer_instance_id}}.service"
    ]
  }
}
