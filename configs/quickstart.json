{
  "policy_path": "configs/policy.target.json",
  "event_path": "var/events.jsonl",
  "response_path": "var/responses.jsonl",
  "artifact_dir": "var/forensics",
  "socket_path": "var/agent.sock",
  "interval_sec": 2,
  "syslog": false,
  "dry_run": true,
  "allowed_uids": [0],

  "retention": {
    "max_bytes": 104857600,
    "max_backups": 5
  },

  "file_watch": {
    "mode": "inotify",
    "paths": ["/etc", "/tmp", "/home", "/root/.ssh"]
  },

  "fanotify": {
    "enabled": true,
    "paths": ["/etc", "/tmp", "/home"]
  },

  "nft": {
    "enabled": false,
    "dry_run": true,
    "table": "edr",
    "chain": "blocklist"
  },

  "bpf": {
    "enabled": true,
    "obj_dir": ".",
    "ringbuf_pages": 512
  },

  "integrity": {
    "enable_chain": false,
    "key_path": "",
    "state_path": "var/events.jsonl.state",
    "algorithm": "sha256"
  },

  "suppression": {
    "process_cooldown_sec": 30,
    "file_cooldown_sec": 60,
    "network_cooldown_sec": 30,
    "rate_per_sec": 20,
    "burst": 20,
    "state_path": "var/suppressor.json"
  },

  "anchor": {
    "enabled": false,
    "url": "",
    "file_path": "",
    "interval_sec": 60
  },

  "rootkit_detection": {
    "enabled": true,
    "interval_sec": 30,
    "monitor_only": true
  },

  "critical_processes": ["sshd", "systemd"],
  "webhooks": []
}
