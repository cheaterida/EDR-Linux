{
  "schema_version": "v0.5",
  "rules": [
    {
      "id": "P001-suspicious-shell-download",
      "description": "Shell command downloads and executes payload-like content",
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "curl http://"
      },
      "whitelist": [
        {
          "process_path": "/usr/bin/apt"
        }
      ]
    },
    {
      "id": "P002-credential-file-access",
      "description": "Process command line references sensitive credential files",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "/etc/shadow"
      }
    },
    {
      "id": "P003-reverse-shell-pattern",
      "description": "Common bash reverse shell command pattern",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/dev/tcp/"
      }
    },
    {
      "id": "P003b-python-reverse-shell",
      "description": "Python socket-based reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "socket.socket"
      }
    },
    {
      "id": "P003c-socat-reverse-shell",
      "description": "Socat exec-based reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "exec:"
      }
    },
    {
      "id": "P003d-perl-reverse-shell",
      "description": "Perl IO::Socket reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "IO::Socket::INET"
      }
    },
    {
      "id": "P003e-ncat-reverse-shell",
      "description": "Ncat execution-based reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "ncat -e"
      }
    },
    {
      "id": "P004-python-listener",
      "description": "Python SimpleHTTPServer-like ad-hoc server",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "http.server"
      }
    },
    {
      "id": "P005-temp-exec",
      "description": "Execution from writable temporary directory",
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/tmp/"
      }
    },
    {
      "id": "N001-suspicious-listener",
      "description": "Suspicious local listener port used by test malware",
      "category": "network",
      "severity": "high",
      "decision": "block",
      "action": "nft_block",
      "match": {
        "protocol": "tcp",
        "local_port": 4444
      }
    },
    {
      "id": "N002-known-bad-remote",
      "description": "Connection to documentation-only bad remote address",
      "category": "network",
      "severity": "high",
      "decision": "block",
      "action": "nft_block",
      "match": {
        "remote_addr": "203.0.113.66"
      }
    },
    {
      "id": "P006-after-hours-admin",
      "description": "Administrative command outside working hours",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "useradd"
      },
      "time_window": {
        "start": "20:00",
        "end": "06:00"
      }
    },
    {
      "id": "F001-policy-change",
      "description": "Policy file modification should always be audited",
      "category": "file",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path": "configs/policy.json"
      }
    },
    {
      "id": "F002-config-permission-guard",
      "description": "Sensitive config directory changes trigger permission hardening",
      "category": "file",
      "severity": "medium",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path_prefix": "configs/",
        "file_op": "write"
      }
    },
    {
      "id": "ATT001-ptrace-self-check",
      "description": "Process uses ptrace self-check (anti-debug technique)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "ptrace_self_check": true
      }
    },
    {
      "id": "ATT002-ld-preload-injection",
      "description": "Process loaded with LD_PRELOAD injection",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "env_contains": "LD_PRELOAD"
      }
    },
    {
      "id": "ATT003-frida-detected",
      "description": "Frida instrumentation framework detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "maps_contains": "frida"
      }
    },
    {
      "id": "ATT004-ld-so-preload-write",
      "description": "Modification of /etc/ld.so.preload",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path": "/etc/ld.so.preload",
        "file_op": "write"
      }
    },
    {
      "id": "SELF001-agent-binary-access",
      "description": "Unauthorized access to EDR agent binary",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fanotify_deny",
      "match": {
        "file_path_prefix": "/opt/edr/",
        "file_op": "open"
      }
    },

    {
      "id": "B001-shadow-access",
      "description": "Access to /etc/shadow password file",
      "category": "file",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path_prefix": "/etc/shadow"
      }
    },
    {
      "id": "B002-ssh-key-access",
      "description": "Access to root SSH private keys",
      "category": "file",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path_prefix": "/root/.ssh/id_"
      }
    },
    {
      "id": "B004-sudoers-modify",
      "description": "Modification of sudoers configuration",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path_prefix": "/etc/sudoers"
      }
    },
    {
      "id": "B005-shadow-cmdline",
      "description": "Command line references /etc/shadow",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/etc/shadow"
      },
      "whitelist": [
        {"process_path": "/usr/bin/passwd"},
        {"process_path": "/usr/sbin/chpasswd"}
      ]
    },

    {
      "id": "B010-suid-exec-escalation",
      "description": "Setting SUID bit on executable (privilege escalation attempt)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "chmod +s"
      }
    },
    {
      "id": "B011-setuid-escalation",
      "description": "Setting setuid bit on executable",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "chmod u+s"
      }
    },
    {
      "id": "B012-cap-setuid",
      "description": "Setting Linux capabilities on executable",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "setcap"
      }
    },

    {
      "id": "B020-evil-winrm",
      "description": "Evil-WinRM lateral movement tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "evil-winrm"
      }
    },
    {
      "id": "B021-crackmapexec",
      "description": "CrackMapExec lateral movement tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "process_name": "crackmapexec"
      }
    },
    {
      "id": "B022-impacket-psexec",
      "description": "Impacket psexec.py lateral movement",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "psexec.py"
      }
    },
    {
      "id": "B023-impacket-wmiexec",
      "description": "Impacket wmiexec.py lateral movement",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "wmiexec.py"
      }
    },
    {
      "id": "B024-impacket-smbexec",
      "description": "Impacket smbexec.py lateral movement",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "smbexec.py"
      }
    },
    {
      "id": "B025-ssh-tunnel",
      "description": "SSH port forwarding tunnel created outside working hours",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "ssh -L"
      },
      "time_window": {
        "start": "22:00",
        "end": "06:00"
      }
    },
    {
      "id": "B026-ssh-reverse-tunnel",
      "description": "SSH reverse tunnel detected (potential C2 channel)",
      "category": "process",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "ssh -R"
      }
    },
    {
      "id": "B027-chisel-client",
      "description": "Chisel tunneling tool client detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "chisel client"
      }
    },
    {
      "id": "B028-proxychains",
      "description": "Proxychains network proxy tool detected",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "process_name": "proxychains"
      }
    },

    {
      "id": "B032-iodine",
      "description": "Iodine DNS tunneling tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "process_name": "iodine"
      }
    },
    {
      "id": "B033-dnscat",
      "description": "dnscat2 DNS tunneling tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "process_name": "dnscat2"
      }
    },

    {
      "id": "B050-crontab-write",
      "description": "Write to user crontab directory (persistence mechanism)",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path_prefix": "/var/spool/cron/",
        "file_op": "write"
      }
    },
    {
      "id": "B051-cron-d-write",
      "description": "Write to /etc/cron.d (persistence mechanism)",
      "category": "file",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path_prefix": "/etc/cron.d/",
        "file_op": "write"
      }
    },
    {
      "id": "B052-systemd-unit-write",
      "description": "Write to systemd service directory (persistence mechanism)",
      "category": "file",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path_prefix": "/etc/systemd/system/",
        "file_op": "write"
      }
    },
    {
      "id": "B053-authorized-keys-write",
      "description": "Write to SSH authorized_keys (backdoor persistence)",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path_suffix": "authorized_keys",
        "file_op": "write"
      }
    },
    {
      "id": "B054-rc-local-write",
      "description": "Write to /etc/rc.local (persistence mechanism)",
      "category": "file",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path": "/etc/rc.local",
        "file_op": "write"
      }
    },
    {
      "id": "B055-bashrc-write",
      "description": "Write to root bashrc (persistence mechanism)",
      "category": "file",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path_prefix": "/root/.bashrc",
        "file_op": "write"
      }
    },
    {
      "id": "B057-systemd-enable",
      "description": "systemctl enable command (persistence mechanism)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "systemctl enable"
      }
    },
    {
      "id": "B058-crontab-cmd",
      "description": "crontab editing command (persistence mechanism)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "crontab -e"
      }
    },

    {
      "id": "B060-nsenter",
      "description": "nsenter targeting PID 1 (container escape attempt)",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "nsenter -t 1"
      }
    },
    {
      "id": "B061-mount-proc-escape",
      "description": "Bind mount /proc (container escape attempt)",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "mount --bind /proc"
      }
    },
    {
      "id": "B062-sysrq-trigger",
      "description": "Access to /proc/sysrq-trigger (kernel manipulation)",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fanotify_deny",
      "match": {
        "file_path": "/proc/sysrq-trigger"
      }
    },
    {
      "id": "B063-core-pattern-escape",
      "description": "Write to /proc/sys/kernel/core_pattern (container escape)",
      "category": "file",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path": "/proc/sys/kernel/core_pattern",
        "file_op": "write"
      }
    },

    {
      "id": "B070-history-clear",
      "description": "Clearing bash command history (anti-forensics)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "history -c"
      }
    },
    {
      "id": "B071-shred-logs",
      "description": "Shredding log files (anti-forensics)",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "shred /var/log"
      }
    },
    {
      "id": "B072-truncate-logs",
      "description": "Truncating log files (anti-forensics)",
      "category": "process",
      "severity": "critical",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "truncate -s 0 /var/log"
      }
    },
    {
      "id": "B074-secure-delete",
      "description": "Secure delete tool usage (anti-forensics)",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "srm "
      }
    },
    {
      "id": "B076-log-redirect-overwrite",
      "description": "Redirect overwriting log files (anti-forensics)",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "> /var/log/"
      }
    },

    {
      "id": "B080-responder",
      "description": "Responder LLMNR/NBT-NS poisoning tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "process_name": "responder"
      }
    },
    {
      "id": "B081-bloodhound",
      "description": "BloodHound AD reconnaissance tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "bloodhound"
      }
    },
    {
      "id": "B082-mimikatz-pattern",
      "description": "Mimikatz-like credential dumping pattern",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "sekurlsa::logonpasswords"
      }
    },
    {
      "id": "B083-lazagne",
      "description": "LaZagne credential recovery tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "process_name": "lazagne"
      }
    },
    {
      "id": "B084-hashcat",
      "description": "Hashcat password cracking tool detected",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "process_name": "hashcat"
      }
    },
    {
      "id": "B085-john",
      "description": "John the Ripper password cracker detected",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "process_name": "john"
      }
    },
    {
      "id": "B086-hydra",
      "description": "Hydra brute-force tool detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "process_name": "hydra"
      }
    },
    {
      "id": "B087-nmap-aggressive",
      "description": "Nmap aggressive scan detected",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "nmap -A"
      }
    },
    {
      "id": "B088-masscan",
      "description": "Masscan port scanner detected",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "process_name": "masscan"
      }
    }
  ],
  "process_access": {
    "mode": "enforce",
    "severity": "high",
    "action": "kill",
    "whitelist": [],
    "blacklist": [
      {"process_name": "nc"},
      {"process_name": "ncat"},
      {"process_path": "/tmp/edr-denied"},
      {"cmdline_contains": "edr_blacklisted_process"},
      {"process_name": "crackmapexec"},
      {"process_name": "evil-winrm"},
      {"process_name": "chisel"},
      {"process_name": "iodine"},
      {"process_name": "dnscat2"},
      {"process_name": "proxychains"},
      {"process_name": "responder"}
    ]
  },
  "self_protection": {
    "enabled": true,
    "audit_severity": "critical",
    "enforce_mode": "kill",
    "shutdown_enabled": true
  }
}
