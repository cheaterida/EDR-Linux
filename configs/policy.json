{
  "schema_version": "v0.1",
  "rules": [
    {
      "id": "P001-suspicious-shell-download",
      "description": "Shell command downloads and executes payload-like content",
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "curl http://"
      },
      "whitelist": [
        {
          "process_path": "/usr/bin/apt"
        }
      ]
    },
    {
      "id": "P002-credential-file-access",
      "description": "Process command line references sensitive credential files",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "/etc/shadow"
      }
    },
    {
      "id": "P003-reverse-shell-pattern",
      "description": "Common bash reverse shell command pattern",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/dev/tcp/"
      }
    },
    {
      "id": "P003b-python-reverse-shell",
      "description": "Python socket-based reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "socket.socket"
      }
    },
    {
      "id": "P003c-socat-reverse-shell",
      "description": "Socat exec-based reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "exec:"
      }
    },
    {
      "id": "P003d-perl-reverse-shell",
      "description": "Perl IO::Socket reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "IO::Socket::INET"
      }
    },
    {
      "id": "P003e-ncat-reverse-shell",
      "description": "Ncat execution-based reverse shell",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "ncat -e"
      }
    },
    {
      "id": "P004-python-listener",
      "description": "Python SimpleHTTPServer-like ad-hoc server",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "http.server"
      }
    },
    {
      "id": "P005-temp-exec",
      "description": "Execution from writable temporary directory",
      "category": "process",
      "severity": "high",
      "decision": "block",
      "action": "kill",
      "match": {
        "cmdline_contains": "/tmp/"
      }
    },
    {
      "id": "N001-suspicious-listener",
      "description": "Suspicious local listener port used by test malware",
      "category": "network",
      "severity": "high",
      "decision": "block",
      "action": "nft_block",
      "match": {
        "protocol": "tcp",
        "local_port": 4444
      }
    },
    {
      "id": "N002-known-bad-remote",
      "description": "Connection to documentation-only bad remote address",
      "category": "network",
      "severity": "high",
      "decision": "block",
      "action": "nft_block",
      "match": {
        "remote_addr": "203.0.113.66"
      }
    },
    {
      "id": "P006-after-hours-admin",
      "description": "Administrative command outside working hours",
      "category": "process",
      "severity": "medium",
      "decision": "alert",
      "action": "none",
      "match": {
        "cmdline_contains": "useradd"
      },
      "time_window": {
        "start": "20:00",
        "end": "06:00"
      }
    },
    {
      "id": "F001-policy-change",
      "description": "Policy file modification should always be audited",
      "category": "file",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "file_path": "configs/policy.json"
      }
    },
    {
      "id": "F002-config-permission-guard",
      "description": "Sensitive config directory changes trigger permission hardening",
      "category": "file",
      "severity": "medium",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path_prefix": "configs/",
        "file_op": "write"
      }
    },
    {
      "id": "ATT001-ptrace-self-check",
      "description": "Process uses ptrace self-check (anti-debug technique)",
      "category": "process",
      "severity": "high",
      "decision": "alert",
      "action": "none",
      "match": {
        "ptrace_self_check": true
      }
    },
    {
      "id": "ATT002-ld-preload-injection",
      "description": "Process loaded with LD_PRELOAD injection",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "env_contains": "LD_PRELOAD"
      }
    },
    {
      "id": "ATT003-frida-detected",
      "description": "Frida instrumentation framework detected",
      "category": "process",
      "severity": "critical",
      "decision": "block",
      "action": "kill",
      "match": {
        "maps_contains": "frida"
      }
    },
    {
      "id": "ATT004-ld-so-preload-write",
      "description": "Modification of /etc/ld.so.preload",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fix_permissions",
      "match": {
        "file_path": "/etc/ld.so.preload",
        "file_op": "write"
      }
    },
    {
      "id": "SELF001-agent-binary-access",
      "description": "Unauthorized access to EDR agent binary",
      "category": "file",
      "severity": "critical",
      "decision": "block",
      "action": "fanotify_deny",
      "match": {
        "file_path_prefix": "/opt/edr/",
        "file_op": "open"
      }
    }
  ],
  "process_access": {
    "mode": "enforce",
    "severity": "high",
    "action": "kill",
    "whitelist": [],
    "blacklist": [
      {
        "process_name": "nc"
      },
      {
        "process_name": "ncat"
      },
      {
        "process_path": "/tmp/edr-denied"
      },
      {
        "cmdline_contains": "edr_blacklisted_process"
      }
    ]
  },
  "self_protection": {
    "enabled": true,
    "audit_severity": "critical",
    "enforce_mode": "kill",
    "shutdown_enabled": true
  }
}
