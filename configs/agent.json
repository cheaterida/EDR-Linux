// =============================================================================
// EDR Agent Configuration
// =============================================================================
// This is a DEV-LOCAL override file. Production deployments use
// /etc/edr/agent.json with paths rooted under /var/lib/edr and
// /var/log/edr.
//
// Convention:
//   Fields marked /* dev */ below are developer-local overrides of
//   the production defaults defined in cmd/edr-agent/main.go loadConfig().
//   Fields without a /* dev */ comment match the production default.
//   Remove /* dev */ lines entirely when generating a deployment config.
// =============================================================================
{
  "policy_path": "configs/policy.json",
  "baseline_path": "configs/baseline.json",
  /* dev */ "event_path": "/home/cheater/edr-runtime/events.jsonl",
  /* dev */ "response_path": "/home/cheater/edr-runtime/responses.jsonl",
  /* dev */ "artifact_dir": "/home/cheater/edr-runtime/forensics",
  /* dev */ "socket_path": "/home/cheater/edr-runtime/edr-agent.sock",
  "interval_sec": 5,
  "syslog": false,
  /* WARNING: dev override — production must use dry_run=true first, then
     switch to false only after validation. allowed_uids must be [0] in prod. */
  "dry_run": true,
  "allowed_uids": [1000],
  "retention": {
    "max_bytes": 1048576,
    "max_backups": 3
  },
  "file_watch": {
    "mode": "inotify",
    "paths": ["configs"]
  },
  "nft": {
    "enabled": false,
    "dry_run": true,
    "table": "edr",
    "chain": "blocklist"
  },
  "integrity": {
    "enable_chain": true,
    /* dev */ "key_path": "/home/cheater/edr-runtime/log.key",
    /* dev */ "state_path": "/home/cheater/edr-runtime/events.jsonl.state",
    "algorithm": "sha256"
  },
  "suppression": {
    "process_cooldown_sec": 30,
    "file_cooldown_sec": 60,
    "network_cooldown_sec": 30,
    "rate_per_sec": 10,
    "burst": 10,
    /* dev */ "state_path": "/home/cheater/edr-runtime/suppressor.json"
  },
  // anchor v0.16 remote log-anchor (push chain head to external endpoint)
  "anchor": {
    "enabled": false,
    "url": "",
    "file_path": "/home/cheater/edr-runtime/anchor.json",
    "interval_sec": 60
  },
  /* dev — code default enabled=false (R-P2); dev override true for BPF testing */
  "bpf": {
    "enabled": true,
    "obj_dir": "internal/bpf/probes",
    "ringbuf_pages": 256,
    /* dev */ "ringbuf_path": "/sys/fs/bpf/edr/events"
  },
  // fanotify v0.3 file-access interposition (requires CAP_SYS_ADMIN)
  // enabled defaults to false — set to true to activate file-open interception
  "fanotify": {
    "enabled": false,
    "paths": ["/etc", "/tmp", "/var/spool/cron", "/usr/local/bin", "/opt/edr", "/etc/edr"]
  },
  /* dev */ "signing_key_path": "/home/cheater/edr-runtime/signing.key"
}
