{
  "policy_path": "configs/policy.json",
  "baseline_path": "configs/baseline.json",
  "event_path": "var/sensor-events.jsonl",
  "response_path": "var/responses.jsonl",
  "artifact_dir": "var/forensics",
  "socket_path": "var/run/edr-agent.sock",
  "interval_sec": 5,
  "dry_run": true,
  "allowed_uids": [0],
  "retention": {
    "max_bytes": 1048576,
    "max_backups": 3
  },
  "file_watch": {
    "mode": "inotify",
    "paths": ["configs"]
  },
  "integrity": {
    "enable_chain": true,
    "key_path": "var/log.key",
    "state_path": "var/sensor-events.jsonl.state",
    "algorithm": "sha256"
  },
  "transport": {
    "sensor_socket": "var/run/edr-sensor.sock",
    "orchestrator_socket": "var/run/edr-orchestrator.sock",
    "enforcer_socket": "var/run/edr-enforcer.sock",
    "shared_secret": "local-dev-secret",
    "event_push_every_sec": 2
  },
  "ha": {
    "instance_id": "edr-a",
    "peer_instance_id": "edr-b",
    "priority": 100,
    "run_dir": "var/run/ha",
    "heartbeat_every_sec": 1,
    "suspect_after": 3,
    "down_after": 5,
    "lease_ttl_sec": 10,
    "restart_cooldown_sec": 30
  }
}
