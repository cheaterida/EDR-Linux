{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EDR v0.1 Policy",
  "type": "object",
  "required": ["schema_version", "rules"],
  "properties": {
    "schema_version": { "const": "v0.1" },
    "process_access": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["monitor", "enforce"] },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "action": { "enum": ["none", "kill"] },
        "whitelist": { "type": "array" },
        "blacklist": { "type": "array" }
      }
    },
    "self_protection": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "audit_severity": { "enum": ["low", "medium", "high", "critical"] },
        "enforce_mode": { "enum": ["kill"] },
        "shutdown_enabled": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "rules": { "type": "array" }
  }
}
